# JWT配置 - 生产环境必须设置强密钥（至少256位）
JWT_SECRET=your-super-secret-jwt-key-at-least-256-bits-long-change-this-in-production

# 管理员配置 - 生产环境必须设置强密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourStrongP@ssw0rd123
ADMIN_EMAIL=admin@mockserver.com

# Swagger认证配置（可选）
SWAGGER_USERNAME=swagger_admin
SWAGGER_PASSWORD=YourSw@ggerP@ss123

# CORS允许的源列表（生产环境必须配置，多个源用逗号分隔）
# 示例: https://example.com,https://app.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 数据库配置（如果使用外部数据库）
DB_URL=jdbc:sqlite:./data/mock-server.db
DB_USERNAME=
DB_PASSWORD=

# 服务器端口
SERVER_PORT=8080
