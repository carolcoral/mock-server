# ========================================
# Mock Server 配置文件
# 所有配置项均可通过环境变量覆盖
# 优先级：环境变量 > .env文件 > 代码默认值
# ========================================

# ========================================
# JWT配置
# 生产环境必须设置强密钥（至少64个字符）
# ========================================
JWT_SECRET=scbcnlsue#TVYbxka73bdlyabjj63glbod4vjb^FRIGBbja63jku^FXYZ123456789ABC
JWT_EXPIRATION=86400000

# ========================================
# 管理员配置
# 首次启动时自动创建管理员账号
# ========================================
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=

# ========================================
# Swagger认证配置
# 用于Swagger UI的登录验证
# ========================================
SWAGGER_USERNAME=
SWAGGER_PASSWORD=

# ========================================
# CORS跨域配置
# 允许的源列表，多个源用逗号分隔
# 示例: https://example.com,https://app.example.com
# ========================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ========================================
# 数据库配置
# SQLite数据库文件路径（相对于项目根目录）
# ========================================
DB_URL=jdbc:sqlite:./data/mock-server.db

# ========================================
# 日志配置
# 日志文件路径（相对于项目根目录）
# ========================================
LOG_FILE_PATH=./logs/mock-server.log

# ========================================
# 服务器配置
# 后端服务监听端口
# ========================================
SERVER_PORT=8080

# ========================================
# 前端配置
# 前端开发服务器端口
# ========================================
FRONTEND_PORT=3000
