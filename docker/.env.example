# ========================================
# Mock Server Docker Compose 环境变量配置
# ========================================

# 宿主机端口（默认 8080）
HOST_PORT=8080

# JWT 配置（生产环境必须使用强密钥）
JWT_SECRET=scbcnlsue#TVYbxka73bdlyabjj63glbod4vjb^FRIGBbja63jku^FXYZ123456789ABC
JWT_EXPIRATION=86400000

# 管理员账号配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123!
ADMIN_EMAIL=admin@mockserver.com

# 时区设置
TZ=Asia/Shanghai

# Java JVM 配置
JAVA_OPTS=-Xmx512m -Xms256m
