# Mock Server Docker Compose 环境变量
# 复制为 .env 后按需修改

# 宿主机端口
HOST_PORT=8080

# JWT 配置（生产环境务必更换强密钥）
JWT_SECRET=scbcnlsue#TVYbxka73bdlyabjj63glbod4vjb^FRIGBbja63jku^FXYZ123456789ABC
JWT_EXPIRATION=86400000

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123!
ADMIN_EMAIL=admin@mockserver.com

# Swagger 认证配置
SWAGGER_USERNAME=swagger_admin
SWAGGER_PASSWORD=Swagger@Admin!

# 时区设置
TZ=Asia/Shanghai

# Java JVM 配置
JAVA_OPTS=-Xmx512m -Xms256m

# ========================================
# 数据库配置
# DB_TYPE 可选值: sqlite | mysql | postgresql
# Docker 部署建议使用 mysql 或 postgresql
# ========================================
DB_TYPE=sqlite

# ----- SQLite 配置（默认，Docker 数据卷挂载到 ./data）-----
DB_URL=jdbc:sqlite:./data/mock-server.db

# ----- MySQL 配置（如需使用 MySQL 请修改 DB_TYPE=mysql 并取消下方注释）-----
# MYSQL_HOST=mysql
# MYSQL_PORT=3306
# MYSQL_DATABASE=mock_server
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=

# ----- PostgreSQL 配置（如需使用 PostgreSQL 请修改 DB_TYPE=postgresql 并取消下方注释）-----
# PGSQL_HOST=postgres
# PGSQL_PORT=5432
# PGSQL_DATABASE=mock_server
# PGSQL_USERNAME=postgres
# PGSQL_PASSWORD=
