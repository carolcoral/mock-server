# ========================================
# Mock Server Docker Compose 环境变量配置
# ========================================

# 宿主机端口（默认 8080）
HOST_PORT=8080

# JWT 配置（生产环境必须使用强密钥）
JWT_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRATION=86400000

# 管理员账号配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
ADMIN_EMAIL=admin@mockserver.com

# Swagger 认证配置
SWAGGER_USERNAME=swagger_admin
SWAGGER_PASSWORD=CHANGE_ME

# 时区设置
TZ=Asia/Shanghai

# Java JVM 配置
JAVA_OPTS=-Xmx512m -Xms256m

# ========================================
# 数据库配置
# DB_TYPE 可选值: sqlite | mysql | postgresql
# Docker 部署建议使用 mysql 或 postgresql
# ========================================
DB_TYPE=sqlite

# ----- SQLite 配置（默认，Docker 数据卷挂载到 ./data）-----
DB_URL=jdbc:sqlite:./data/mock-server.db

# ----- MySQL 配置（如需使用 MySQL 请修改 DB_TYPE=mysql 并取消下方注释）-----
# MYSQL_HOST=mysql
# MYSQL_PORT=3306
# MYSQL_DATABASE=mock_server
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=CHANGE_ME

# ----- PostgreSQL 配置（如需使用 PostgreSQL 请修改 DB_TYPE=postgresql 并取消下方注释）-----
# PGSQL_HOST=postgres
# PGSQL_PORT=5432
# PGSQL_DATABASE=mock_server
# PGSQL_USERNAME=postgres
# PGSQL_PASSWORD=CHANGE_ME
