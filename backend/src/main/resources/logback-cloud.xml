<?xml version="1.0" encoding="UTF-8"?>
<!-- 云原生环境日志配置 -->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    
    <!-- 云环境变量 -->
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="mock-server"/>
    <springProperty scope="context" name="instanceId" source="INSTANCE_ID" defaultValue="localhost"/>
    
    <!-- 控制台输出格式（JSON格式，便于日志收集） -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- 包含完整信息 -->
            <includeContext>true</includeContext>
            <includeMdc>true</includeMdc>
            <includeCallerData>true</includeCallerData>
            
            <!-- 自定义字段 -->
            <customFields>
                {
                    "app":"${appName}",
                    "instance":"${instanceId}",
                    "env":"cloud"
                }
            </customFields>
            
            <!-- 时间戳格式 -->
            <timeZone>Asia/Shanghai</timeZone>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZZ</timestampPattern>
        </encoder>
    </appender>
    
    <!-- 文件输出（轮转） -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/app/logs/mock-server.log</file>
        
        <!-- 轮转策略 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 日志文件命名 -->
            <fileNamePattern>/app/logs/mock-server.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            
            <!-- 日志保留策略 -->
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
            
            <!-- 清理策略 -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        
        <!-- 编码器 -->
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId}] %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        
        <!-- 触发器（按级别） -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>
    
    <!-- 错误日志单独输出 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/app/logs/mock-server-error.log</file>
        
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>/app/logs/mock-server-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId}] %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        
        <!-- 只记录错误 -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>
    
    <!-- SQL日志（开发调试用） -->
    <appender name="SQL_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/app/logs/mock-server-sql.log</file>
        
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>/app/logs/mock-server-sql.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- 异步日志（提高性能） -->
    <appender name="ASYNC_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="CONSOLE"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>true</includeCallerData>
        <neverBlock>true</neverBlock>
    </appender>
    
    <!-- 根日志级别 -->
    <root level="INFO">
        <appender-ref ref="ASYNC_CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>
    
    <!-- Spring框架日志 -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="WARN"/>
    
    <!-- Hibernate日志 -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.hibernate.SQL" level="DEBUG">
        <appender-ref ref="SQL_FILE"/>
    </logger>
    <logger name="org.hibernate.type.descriptor.sql" level="TRACE">
        <appender-ref ref="SQL_FILE"/>
    </logger>
    
    <!-- 应用日志 -->
    <logger name="com.carolcoral.mockserver" level="INFO"/>
    <logger name="com.carolcoral.mockserver.service" level="DEBUG"/>
    <logger name="com.carolcoral.mockserver.controller" level="DEBUG"/>
    
    <!-- 过滤器日志 -->
    <logger name="com.carolcoral.mockserver.filter" level="DEBUG"/>
    
    <!-- 缓存日志 -->
    <logger name="com.carolcoral.mockserver.util.CacheUtil" level="DEBUG"/>
    
    <!-- Swagger日志 -->
    <logger name="org.springdoc" level="INFO"/>
    
    <!-- 第三方库日志 -->
    <logger name="org.apache.catalina" level="WARN"/>
    <logger name="org.apache.tomcat" level="WARN"/>
    <logger name="org.apache.coyote" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="INFO"/>
    
    <!-- 健康检查日志（减少噪音） -->
    <logger name="org.springframework.boot.actuate" level="WARN"/>
    
    <!-- 云SDK日志 -->
    <logger name="com.qcloud" level="INFO"/>
    <logger name="com.tencent" level="INFO"/>
</configuration>
