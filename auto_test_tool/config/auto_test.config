# ============================================
# Mock Server 自动化测试配置文件
# ============================================

# 系统基础配置
[system]
# 系统访问地址
base_url = http://localhost:8080
# API 前缀
api_prefix = /api
# 请求超时时间（秒）
timeout = 30
# 测试间等待时间（毫秒）
test_interval_ms = 500

# 管理员账号（默认管理员，拥有全部权限）
[admin]
username = admin
password = CHANGE_ME

# AI 相关配置
[ai]
# AI API 地址
api_url = https://ark.cn-beijing.volces.com/api/v3/responses
# AI API Key
api_key = YOUR_API_KEY_HERE
# 模型列表（按优先级排序，不可用时自动切换到下一个）
models = ["doubao-seed-2-0-mini-260428", "doubao-seed-2-0-lite-260428", "deepseek-v4-flash-260425"]
# AI 请求超时（秒）
ai_timeout = 120
# AI 测试时的提示词模板
ai_test_prompt = 请用中文回复"你好，自动化测试通过"，不要回复其他内容。

# 测试范围配置
[test_scope]
# 是否测试公开页面（无需登录）
test_public_pages = true
# 是否测试需认证页面（需登录）
test_authenticated_pages = true
# 是否测试所有页面功能（CRUD 操作）
test_page_features = true
# 是否测试 RBAC 权限控制
test_rbac = true
# 是否测试 AI 功能
test_ai_features = true
# 是否测试安全特性（登录锁定、密码策略等）
test_security_features = true
# 是否测试注册流程
test_registration = true

# 测试账号生成配置
[test_accounts]
# 是否自动创建测试账号
auto_create_accounts = true
# 测试账号前缀
username_prefix = autotest_
# 测试账号默认密码
default_password = CHANGE_ME
# 测试完成后是否清理账号
cleanup_after_test = true

# 邮箱服务配置（用于忘记密码等邮件相关测试）
[email]
# SMTP 服务器地址
smtp_host = YOUR_SMTP_HOST
# SMTP 端口
smtp_port = 465
# 发件邮箱
from_email = YOUR_EMAIL
# 邮箱授权码
auth_code = YOUR_EMAIL_AUTH_CODE
# 是否启用 SSL
use_ssl = true

# 报告配置
[report]
# 报告输出目录
output_dir = ./reports
# 报告格式（json, html, markdown）
formats = ["json", "html", "markdown"]
# 是否输出详细日志
verbose = true
# 是否在控制台实时输出测试进度
console_progress = true
